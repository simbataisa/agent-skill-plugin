{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '[ -f \".claude/hooks/enforce-conventions.sh\" ] && bash \".claude/hooks/enforce-conventions.sh\" \"$CLAUDE_TOOL_INPUT_PATH\" \"$CLAUDE_TOOL_INPUT_CONTENT\" || exit 0'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '[ -f \".claude/hooks/check-bmad-context.sh\" ] && bash \".claude/hooks/check-bmad-context.sh\" || exit 0'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '[ -f \".claude/hooks/auto-handoff-log.sh\" ] && bash \".claude/hooks/auto-handoff-log.sh\" \"$CLAUDE_TOOL_INPUT_PATH\" || exit 0'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '[ -f \".claude/hooks/session-summary.sh\" ] && bash \".claude/hooks/session-summary.sh\" || exit 0'"
          }
        ]
      }
    ]
  }
}
