<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-03-20T00:00:00.000Z" agent="Claude" version="26.0">
  <diagram name="User Registration Flowchart" id="flowchart1">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Start -->
        <mxCell id="start" value="Start" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="345" y="30" width="100" height="60" as="geometry" />
        </mxCell>

        <!-- User enters email -->
        <mxCell id="input_email" value="User Enters Email" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="315" y="130" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- Check if email exists -->
        <mxCell id="check_email" value="Email Exists?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="345" y="240" width="100" height="100" as="geometry" />
        </mxCell>

        <!-- Show error message -->
        <mxCell id="error_msg" value="Show Error&#10;Message" style="whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="540" y="260" width="120" height="60" as="geometry" />
        </mxCell>

        <!-- Create account -->
        <mxCell id="create_account" value="Create Account" style="whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="335" y="390" width="120" height="60" as="geometry" />
        </mxCell>

        <!-- Send verification email -->
        <mxCell id="send_email" value="Send Verification&#10;Email" style="whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="335" y="500" width="120" height="60" as="geometry" />
        </mxCell>

        <!-- Done -->
        <mxCell id="done" value="Done" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="345" y="610" width="100" height="60" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <!-- Start to Input Email -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;endFill=1;" edge="1" parent="1" source="start" target="input_email">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Input Email to Check Email -->
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;endFill=1;" edge="1" parent="1" source="input_email" target="check_email">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Check Email to Error (Yes path) -->
        <mxCell id="e3" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;endFill=1;" edge="1" parent="1" source="check_email" target="error_msg">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Check Email to Create Account (No path) -->
        <mxCell id="e4" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;endFill=1;" edge="1" parent="1" source="check_email" target="create_account">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Error Message back to Input Email (loop) -->
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;endFill=1;" edge="1" parent="1" source="error_msg" target="input_email">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="600" y="160" />
              <mxPoint x="395" y="160" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Create Account to Send Email -->
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;endFill=1;" edge="1" parent="1" source="create_account" target="send_email">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Send Email to Done -->
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;endFill=1;" edge="1" parent="1" source="send_email" target="done">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
