<mxfile host="drawio" modified="2026-03-20T00:00:00.000Z" agent="5.0" etag="abc123" version="20.0" type="device">
  <diagram id="registration-flow" name="User Registration Process">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" background="#ffffff" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Start -->
        <mxCell id="start" value="Start" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#90EE90;" vertex="1" parent="1">
          <mxGeometry x="375" y="20" width="100" height="100" as="geometry" />
        </mxCell>

        <!-- User enters email -->
        <mxCell id="input" value="User Enters Email" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#87CEEB;" vertex="1" parent="1">
          <mxGeometry x="350" y="150" width="150" height="80" as="geometry" />
        </mxCell>

        <!-- System checks if email exists -->
        <mxCell id="check" value="Email Already Exists?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFD700;" vertex="1" parent="1">
          <mxGeometry x="375" y="290" width="100" height="100" as="geometry" />
        </mxCell>

        <!-- Error message (Yes branch) -->
        <mxCell id="error" value="Show Error Message" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFB6C6;" vertex="1" parent="1">
          <mxGeometry x="150" y="305" width="150" height="70" as="geometry" />
        </mxCell>

        <!-- Create account (No branch) -->
        <mxCell id="create" value="Create Account" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#87CEEB;" vertex="1" parent="1">
          <mxGeometry x="550" y="305" width="150" height="70" as="geometry" />
        </mxCell>

        <!-- Send verification email -->
        <mxCell id="verify" value="Send Verification Email" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#87CEEB;" vertex="1" parent="1">
          <mxGeometry x="550" y="450" width="150" height="80" as="geometry" />
        </mxCell>

        <!-- End -->
        <mxCell id="end" value="Done" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#90EE90;" vertex="1" parent="1">
          <mxGeometry x="575" y="600" width="100" height="100" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <mxCell id="edge1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="start" target="input">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="edge2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="input" target="check">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Yes branch to error -->
        <mxCell id="edge3" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="check" target="error">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="350" y="340" as="sourcePoint" />
          </mxGeometry>
        </mxCell>

        <!-- No branch to create -->
        <mxCell id="edge4" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="check" target="create">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="450" y="340" as="sourcePoint" />
          </mxGeometry>
        </mxCell>

        <!-- Error back to input -->
        <mxCell id="edge5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="error" target="input">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="100" y="200" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Create to verify -->
        <mxCell id="edge6" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="create" target="verify">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Verify to end -->
        <mxCell id="edge7" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="verify" target="end">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>